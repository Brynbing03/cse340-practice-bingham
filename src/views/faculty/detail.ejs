<%- include('../partials/header') %>

<main>

  <div class="faculty-detail-header">

    <!-- added the faculty profile image -->
    <img 
      src="/images/faculty/<%= faculty.slug %>.jpg" 
      alt="Photo of <%= faculty.name %>" 
      class="faculty-detail-photo"
    />

    <div class="faculty-detail-info">
      <h1><%= faculty.name %></h1>
      <p class="course-meta">
        <%= faculty.department %> • <%= faculty.title %>
      </p>
    </div>

  </div>

  <div class="sections">
    <div class="section-list">

      <div class="section-card">
        <div class="section-time">Office</div>
        <div class="section-room"><%= faculty.office %></div>
      </div>

      <div class="section-card">
        <div class="section-time">Phone</div>
        <div class="section-room"><%= faculty.phone %></div>
      </div>

      <div class="section-card">
        <div class="section-time">Email</div>
        <div class="section-room">
          <a href="mailto:<%= faculty.email %>"><%= faculty.email %></a>
        </div>
      </div>

    </div>
  </div>

  <div class="navigation">
    <p><a href="/faculty">&larr; Back to Faculty Directory</a></p>
  </div>

</main>

<%- include('../partials/footer') %>